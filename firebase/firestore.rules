rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    // 管理者判定：admins/{uid} ドキュメントが存在すれば管理者
    // （あなたのUIDを Firebase コンソールで admins コレクションに手動追加する）
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ---- ユーザープロフィール（非公開・email等を含む） ----
    match /users/{uid} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if request.auth.uid == uid || isAdmin();
      allow delete: if isAdmin();

      // 保存した投稿（ブックマーク）。本人だけが読み書きできる。
      match /saves/{articleId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }

      // フォロー中リスト（自分がフォローしている相手）。数は誰でも閲覧、編集は本人のみ。
      match /following/{targetUid} {
        allow read:  if true;
        allow write: if isSignedIn() && request.auth.uid == uid;
      }

      // フォロワーリスト（自分をフォローしている人）。数は誰でも閲覧。
      // 追加・削除は「フォローする本人」が自分のUIDを出し入れする。
      match /followers/{followerUid} {
        allow read:  if true;
        allow write: if isSignedIn() && request.auth.uid == followerUid;
      }
    }

    // ---- 公開プロフィール（名前・アイコン・自己紹介・SNSのみ／誰でも閲覧可） ----
    // 記事ページの執筆者カードが未ログイン訪問者にも見せるために使う。
    match /publicProfiles/{uid} {
      allow read:  if true;
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // ---- 管理者リスト（コンソールからのみ編集） ----
    // UID のみを保持（機密情報なし）。管理者バッジ表示のため公開読み取り可。
    match /admins/{uid} {
      allow read:  if true;
      allow write: if false;
    }

    // ---- 記事 ----
    match /articles/{articleId} {

      // 公開記事は誰でも閲覧可。下書き/承認待ちは本人と管理者のみ。
      allow read: if resource.data.status == 'published'
                  || (isSignedIn() && resource.data.authorId == request.auth.uid)
                  || isAdmin();

      // 作成：ログイン必須・自分を著者にする・status は必ず 'pending'
      allow create: if isSignedIn()
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.status == 'pending';

      // 更新：管理者は何でも可（承認＝status変更を含む）。
      //       著者は自分の記事を編集可。ただし status は自分で変えられない。
      allow update: if isAdmin()
                    || (isSignedIn()
                        && resource.data.authorId == request.auth.uid
                        && request.resource.data.authorId == request.auth.uid
                        && request.resource.data.status == resource.data.status);

      // 削除：管理者、または自分の記事
      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.authorId == request.auth.uid);

      // いいね： articles/{id}/likes/{uid}。数は誰でも閲覧、付け外しは本人のみ。
      match /likes/{likeUid} {
        allow read: if true;
        allow create, delete: if isSignedIn() && request.auth.uid == likeUid;
      }

      // コメント： articles/{id}/comments/{commentId}。誰でも閲覧。
      // 投稿はログインユーザー（自分を著者にする・本文1〜1000文字）。
      // 削除は管理者またはコメント本人。編集は不可。
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
                      && request.resource.data.authorId == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 1000;
        allow delete: if isAdmin()
                      || (isSignedIn() && resource.data.authorId == request.auth.uid);
      }
    }
  }
}
